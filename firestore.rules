rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user has Admin role
    function isAdmin() {
      return request.auth != null && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         request.auth.uid == 'wspQno67bPbz9u47xn5GgRl8MME3' || 
         request.auth.uid == 'df6QPQBEZMWsyc7VHQ5K8ofLOzE2');
    }

    // Helper function to check if user has Teacher role
    function isTeacher() {
      return request.auth != null && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Teacher' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin') ||
         request.auth.uid == 'wspQno67bPbz9u47xn5GgRl8MME3' || 
         request.auth.uid == 'df6QPQBEZMWsyc7VHQ5K8ofLOzE2');
    }

    // Users collection - protect against Role Escalation
    match /users/{uid} {
      allow read: if true; // Public read to allow role check in auth state callback
      allow create: if request.auth != null && request.auth.uid == uid && 
                     (!('role' in request.resource.data) || isAdmin());
      allow update: if request.auth != null && request.auth.uid == uid && 
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());
      allow delete: if isAdmin();
    }

    // Idempotency Keys registry
    match /idempotency_keys/{operationId} {
      allow create: if request.auth != null && !exists(/databases/$(database)/documents/idempotency_keys/$(operationId));
      allow read: if request.auth != null;
    }

    // Parent verification sessions
    match /parent_sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid &&
        exists(/databases/$(database)/documents/students/$(request.resource.data.studentId)) &&
        (
          get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data['رقم الهاتف'] == request.resource.data.phone ||
          get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data.phone == request.resource.data.phone
        );
    }

    // Students collection
    match /students/{studentId} {
      allow get: if true; // Public read access for parent portal
      allow list: if isAdmin() || isTeacher();
      allow create: if isAdmin() || request.resource.data['حالة الطلب'] == 'قيد المراجعة';
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    // Student ID recovery mappings
    match /student_recovery/{phone} {
      allow get: if true; // Public read access for student recovery without anonymous auth
      allow write: if isAdmin() || isTeacher();
    }

    // point collection (student points ledger) - protect against unauthorized creation
    match /point/{studentId} {
      allow read: if true; // Public read access for parent portal
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    // Presence collection
    match /Presence/{presenceId} {
      allow read: if true; // Public read access for parent portal
      allow write: if isAdmin() || isTeacher();
    }

    // Ratings collection
    match /Ratings/{ratingId} {
      allow read: if true; // Public read access for parent portal
      allow write: if isAdmin() || isTeacher();
    }

    // sessions collection
    match /sessions/{sessionId} {
      allow read: if true; // Public read access for parent portal
      allow write: if isAdmin() || isTeacher();
    }

    // settings collection
    match /settings/{settingId} {
      allow read: if true; // Public settings
      allow write: if isAdmin() || (settingId == 'recovery_index_built_v1' && isTeacher());
    }

    // lessons collection
    match /lessons/{lessonId} {
      allow read: if true; // Public timetable
      allow write: if isAdmin();
    }

    // Adult Quranic Circle collections
    match /adult_participants/{docId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher() || request.resource.data.status == 'قيد المراجعة';
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /adult_progress/{docId} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    // Adult verification sessions
    match /adult_sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid &&
        exists(/databases/$(database)/documents/adult_participants/$(request.resource.data.adultId)) &&
        (
          get(/databases/$(database)/documents/adult_participants/$(request.resource.data.adultId)).data.phone == request.resource.data.phone
        );
    }
  }
}
